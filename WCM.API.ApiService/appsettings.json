{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName" ],
    "Properties": {
      "Application": "WCM.API"
    }
  },

  "AllowedHosts": "localhost;127.0.0.1;*.urbaser.com;*.azurewebsites.net",

  "KeyVault": {
    "Endpoint": ""
  },

  "ConnectionStrings": {
    "wcmdb": ""
  },

  "AzureEntraId": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "",
    "ClientId": "",
    "AllowWebApiToBeAuthorizedByACL": true
  },

  "RateLimiting": {
    "PermitLimit": 100,
    "WindowInSeconds": 60,
    "QueueLimit": 10
  },

  "MediatR": {
    "LicenseKey": ""
  }
}
