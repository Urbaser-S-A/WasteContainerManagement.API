{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "System": "Warning"
      }
    }
  },

  "RateLimiting": {
    "PermitLimit": 500,
    "WindowInSeconds": 60,
    "QueueLimit": 20
  }
}
